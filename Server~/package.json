{
  "name": "nx3-unity-mcp-server",
  "version": "0.1.0",
  "description": "Bundled MCP server for ProjectM Unity QA automation.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "nx3-unity-mcp-server": "build/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=build/index.js --banner:js=\"#!/usr/bin/env node\" --log-override:package.json=silent",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
